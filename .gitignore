# NDB 単体プロジェクト用（Hub ルート .gitignore と整合）

# ============================================================
# AI・IDE ツール設定フォルダ
# ============================================================
.antigravity/
.claude/
.cursor/
.gemini/
.obsidian/
.serena/
.vscode/

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
.env
.env.*
*.egg-info/

# ============================================================
# NDB 生データ（絶対除外）
# ============================================================
02_Data/raw/
02_Data/processed/
data/raw/

# ============================================================
# 中間データ・解析キャッシュ（再生成可能）
# ============================================================
data/interim/
*.parquet
*.sqlite
*.db

# ============================================================
# ログ・一時ファイル
# ============================================================
*.log
results/logs/
*.tmp

# ============================================================
# 外部データ（再ダウンロード可能・バイナリ）
# ============================================================
data/external/*.xlsx
data/external/estat_search_results.csv

# ============================================================
# 原稿 DOCX（バイナリ・大容量・著者情報含む）
# ============================================================
04_Manuscripts/*.docx
04_Manuscripts/submission_package_JCH/*.docx

# ============================================================
# 著作権保護コンテンツ（出版社の投稿規定 PDF 等）
# ============================================================
04_Manuscripts/submission_package_JCH/*.pdf

# ============================================================
# デスクトップ用フォルダ（ローカル作業用）
# ============================================================
デスクトップ用/

# ============================================================
# OS・エディタ
# ============================================================
.DS_Store
Thumbs.db
desktop.ini
.git.disabled_*/
**/.git.nested_repo_backup/

# ============================================================
# GitHub 100MB 制限（大容量ジオデータ・アーカイブ）
# ============================================================
*.geojson
*.shp
*.dbf
*.shx
*.prj
*.zip
*.7z
*.pkl
*.xml
data/raw/MLIT_N03/
**/MLIT_N03/
